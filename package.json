{
  "private": true,
  "name": "@devjskit/github-workflows",
  "version": "0.1.0-alpha.1",
  "author": "Billgo <hi@billgo.me>",
  "description": "Reusable GitHub Actions for TypeScript projects.",
  "license": "MIT",
  "repository": "git+ssh://git@github.com:devjskit/github-workflows.git",
  "packageManager": "bun@1.3.13",
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bunx --bun tsdown --config tsdown.config.mts",
    "dev": "bunx --bun tsdown --config-loader unrun --watch",
    "format": "bunx --bun biome check --write .",
    "lint": "bunx --bun biome check .",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "bunx --bun tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@devjskit/biome-config": "^0.2.2",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
